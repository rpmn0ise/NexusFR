{% macro resourceCard(r, essential=false) %}
<div class="resource-card{% if essential %} essential{% endif %}" data-tags="{% if r.tags %}{{ r.tags | join(' ') }}{% endif %}">
  <div class="resource-header">
    <span class="resource-name">
      <a href="{{ r.url }}" target="_blank" rel="noopener noreferrer">{{ r.name }}</a>
    </span>
    {% if r.guide and r.guide != "null" %}
      <a href="{{ ('/guides/' + r.guide + '/') | url }}" class="resource-guide">guide</a>
    {% endif %}
  </div>
  <div class="resource-meta">
    <span class="resource-usage">{{ r.usage }}</span>
    <span class="resource-why">{{ r.why }}</span>
  </div>
  <div class="resource-side">
    <span class="resource-status">
      {% if r.status === "ok" %}✅
      {% elif r.status === "dead" %}❌
      {% elif r.status === "unstable" %}⚠️
      {% else %}❓
      {% endif %}
    </span>
    <div class="resource-tags">
      {% for tag in r.tags %}
        <span class="tag">
          {% if tag === "fr" %}🇫🇷
          {% elif tag === "fast" %}⚡
          {% elif tag === "safe" %}🛡️
          {% elif tag === "advanced" %}🧠
          {% elif tag === "beginner" %}👶
          {% else %}{{ tag }}
          {% endif %}
        </span>
      {% endfor %}
    </div>
    <span class="resource-verified mono">{{ r.verified }}</span>
  </div>
</div>
{% endmacro %}
