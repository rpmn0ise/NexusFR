---
layout: layouts/base.njk
---

<div class="container">
<div class="guide-page">

  <div class="breadcrumb" style="padding-top:40px;">
    <a href="/">nexus.fr</a>
    <span class="breadcrumb-sep">/</span>
    <a href="/guides/">guides</a>
    <span class="breadcrumb-sep">/</span>
    <span>{{ title }}</span>
  </div>

  <div style="margin-top:24px; margin-bottom:32px; padding-bottom:24px; border-bottom:1px solid var(--border);">
    <div style="font-family:var(--font-mono);font-size:0.75rem;color:var(--accent);margin-bottom:8px;letter-spacing:0.1em;text-transform:uppercase;">
      // guide — {{ category or "général" }}
    </div>
    <h1 style="font-size:clamp(1.4rem,4vw,2rem);font-weight:800;letter-spacing:-0.02em;margin-bottom:8px;">{{ title }}</h1>
    {% if description %}
      <p style="color:var(--text-muted);font-size:0.9rem;">{{ description }}</p>
    {% endif %}
    <div style="display:flex;gap:12px;margin-top:12px;flex-wrap:wrap;">
      {% if level %}<span style="font-size:0.8rem;color:var(--text-dim);">{{ level }}</span>{% endif %}
      {% if readtime %}<span style="font-family:var(--font-mono);font-size:0.7rem;color:var(--text-dim);">~{{ readtime }}</span>{% endif %}
      {% if updated %}<span style="font-family:var(--font-mono);font-size:0.7rem;color:var(--text-dim);">mis à jour : {{ updated }}</span>{% endif %}
    </div>
  </div>

  {{ content | safe }}

</div>
</div>
