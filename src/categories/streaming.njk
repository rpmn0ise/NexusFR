---
layout: layouts/base.njk
title: Streaming
description: "Sites de streaming fiables — films, séries, anime, musique en français."
permalink: /categories/streaming/index.html
---

{% from "components/resource-card.njk" import resourceCard %}

{% set allRes = collections.resources | byCat("streaming") %}
{% set films = allRes | bySub("films") %}
{% set anime = allRes | bySub("anime") %}
{% set music = allRes | bySub("music") %}

<div class="cat-page-header">
  <div class="container">
    <div class="breadcrumb">
      <a href="{{ '/' | url }}">nexus.fr</a>
      <span class="breadcrumb-sep">/</span>
      <span>streaming</span>
    </div>
    <h1 class="cat-page-title"><span>📡</span> Streaming</h1>
    <p class="cat-page-desc">Sites vérifiés pour regarder films, séries, anime et écouter de la musique.</p>
    <div class="filter-bar">
      <span class="mono muted" style="font-size:0.75rem;align-self:center;">filtrer :</span>
      <button class="filter-btn active" data-filter="all">tous</button>
      <button class="filter-btn" data-filter="fr">🇫🇷 français</button>
      <button class="filter-btn" data-filter="fast">⚡ rapide</button>
      <button class="filter-btn" data-filter="beginner">👶 débutant</button>
    </div>
  </div>
</div>

<div class="container">

  {% if films.length %}
  <div class="subsection">
    <div class="subsection-header">
      <span class="subsection-title">Films & Séries</span>
      <span class="subsection-label label-essential">essentiel</span>
    </div>
    <div class="resource-list">
      {% for item in films | essential %}
        {{ resourceCard(item.data, true) }}
      {% endfor %}
    </div>
    {% if films | notEssential | length %}
    <div class="subsection-header mt-16">
      <span class="subsection-label label-list">liste complète</span>
    </div>
    <div class="resource-list">
      {% for item in films | notEssential %}
        {{ resourceCard(item.data) }}
      {% endfor %}
    </div>
    {% endif %}
  </div>
  {% endif %}

  {% if anime.length %}
  <div class="subsection">
    <div class="subsection-header">
      <span class="subsection-title">Anime</span>
      <span class="subsection-label label-essential">essentiel</span>
    </div>
    <div class="resource-list">
      {% for item in anime | essential %}
        {{ resourceCard(item.data, true) }}
      {% endfor %}
    </div>
    {% if anime | notEssential | length %}
    <div class="subsection-header mt-16">
      <span class="subsection-label label-list">liste complète</span>
    </div>
    <div class="resource-list">
      {% for item in anime | notEssential %}
        {{ resourceCard(item.data) }}
      {% endfor %}
    </div>
    {% endif %}
  </div>
  {% endif %}

  {% if music.length %}
  <div class="subsection">
    <div class="subsection-header">
      <span class="subsection-title">Musique</span>
    </div>
    <div class="resource-list">
      {% for item in music %}
        {{ resourceCard(item.data, item.data.essential) }}
      {% endfor %}
    </div>
  </div>
  {% endif %}

  <div class="subsection">
    <div class="subsection-header">
      <span class="subsection-title">Guides associés</span>
    </div>
    <div class="guide-grid">
      <a href="{{ '/guides/guide-telecharger-musique/' | url }}" class="guide-card">
        <span class="guide-tag">// musique</span>
        <span class="guide-title">Télécharger sa musique depuis Spotify</span>
        <span class="guide-desc">SpotiFlyer, Deemix — guide complet</span>
        <span class="guide-level">🧠 avancé</span>
      </a>
    </div>
  </div>

</div>
