---
layout: layouts/base.njk
title: Outils
description: "Outils de conversion, privacy et stockage — sélection ultra-filtrée."
permalink: /categories/tools/index.html
---

{% from "components/resource-card.njk" import resourceCard %}

{% set allRes = collections.resources | byCat("tools") %}
{% set conversion = allRes | bySub("conversion") %}
{% set privacy = allRes | bySub("privacy") %}
{% set upload = allRes | bySub("upload") %}

<div class="cat-page-header">
  <div class="container">
    <div class="breadcrumb">
      <a href="{{ '/' | url }}">nexus.fr</a>
      <span class="breadcrumb-sep">/</span>
      <span>outils</span>
    </div>
    <h1 class="cat-page-title"><span>🔧</span> Outils</h1>
    <p class="cat-page-desc">Conversion, confidentialité, stockage. Chaque outil ici est open source ou audité.</p>
    <div class="filter-bar">
      <span class="mono muted" style="font-size:0.75rem;align-self:center;">filtrer :</span>
      <button class="filter-btn active" data-filter="all">tous</button>
      <button class="filter-btn" data-filter="safe">🛡️ safe</button>
      <button class="filter-btn" data-filter="beginner">👶 débutant</button>
      <button class="filter-btn" data-filter="advanced">🧠 avancé</button>
    </div>
  </div>
</div>

<div class="container">

  {% if conversion.length %}
  <div class="subsection">
    <div class="subsection-header">
      <span class="subsection-title">Conversion & Téléchargement</span>
      <span class="subsection-label label-essential">essentiel</span>
    </div>
    <div class="resource-list">
      {% for item in conversion | essential %}
        {{ resourceCard(item.data, true) }}
      {% endfor %}
    </div>
    {% if conversion | notEssential | length %}
    <div class="subsection-header mt-16">
      <span class="subsection-label label-list">liste complète</span>
    </div>
    <div class="resource-list">
      {% for item in conversion | notEssential %}
        {{ resourceCard(item.data) }}
      {% endfor %}
    </div>
    {% endif %}
  </div>
  {% endif %}

  {% if privacy.length %}
  <div class="subsection">
    <div class="subsection-header">
      <span class="subsection-title">Privacy & Sécurité</span>
      <span class="subsection-label label-essential">essentiel</span>
    </div>
    <div class="resource-list">
      {% for item in privacy | essential %}
        {{ resourceCard(item.data, true) }}
      {% endfor %}
    </div>
    {% if privacy | notEssential | length %}
    <div class="subsection-header mt-16">
      <span class="subsection-label label-list">liste complète</span>
    </div>
    <div class="resource-list">
      {% for item in privacy | notEssential %}
        {{ resourceCard(item.data) }}
      {% endfor %}
    </div>
    {% endif %}
  </div>
  {% endif %}

  {% if upload.length %}
  <div class="subsection">
    <div class="subsection-header">
      <span class="subsection-title">Upload & Stockage</span>
    </div>
    <div class="resource-list">
      {% for item in upload %}
        {{ resourceCard(item.data, item.data.essential) }}
      {% endfor %}
    </div>
  </div>
  {% endif %}

  <div class="subsection">
    <div class="subsection-header">
      <span class="subsection-title">Guides associés</span>
    </div>
    <div class="guide-grid">
      <a href="{{ '/guides/guide-yt-dlp/' | url }}" class="guide-card">
        <span class="guide-tag">// cli</span>
        <span class="guide-title">yt-dlp en pratique</span>
        <span class="guide-desc">Télécharger n'importe quelle vidéo ou playlist en 2 commandes</span>
        <span class="guide-level">🧠 avancé</span>
      </a>
      <a href="{{ '/guides/guide-ublock/' | url }}" class="guide-card">
        <span class="guide-tag">// privacy</span>
        <span class="guide-title">uBlock Origin — config optimale</span>
        <span class="guide-desc">Filtres recommandés pour bloquer pubs, trackers et popups agressifs</span>
        <span class="guide-level">👶 débutant</span>
      </a>
    </div>
  </div>

</div>
