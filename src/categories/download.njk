---

{% from "components/resource-card.njk" import resourceCard %}

<div class="cat-page-header">
  <div class="container">
    <div class="breadcrumb">
      <a href="{{ '/' | url }}">nexus.fr</a>
      <span class="breadcrumb-sep">/</span>
      <span>download</span>
    </div>
    <h1 class="cat-page-title">
      <span>⬇️</span> Download
    </h1>
    <p class="cat-page-desc">Torrents, téléchargement direct et débrideurs. Fiables, vérifiés.</p>

    <div class="filter-bar">
      <span class="mono muted" style="font-size:0.75rem;align-self:center;">filtrer :</span>
      <button class="filter-btn active" data-filter="all">tous</button>
      <button class="filter-btn" data-filter="fast">⚡ rapide</button>
      <button class="filter-btn" data-filter="safe">🛡️ safe</button>
      <button class="filter-btn" data-filter="advanced">🧠 avancé</button>
    </div>
  </div>
</div>

<div class="container">

  <div class="subsection">
    <div class="subsection-header">
      <span class="subsection-title">Torrents</span>
      <span class="subsection-label label-essential">essentiel</span>
    </div>
    <div class="resource-list">
      {{ resourceCard(resources.download.torrents[0], true) }}
      {{ resourceCard(resources.download.torrents[2], true) }}
    </div>

    <div class="subsection-header mt-16">
      <span class="subsection-label label-list">liste complète</span>
    </div>
    <div class="resource-list">
      {{ resourceCard(resources.download.torrents[1]) }}
    </div>
  </div>

  <div class="subsection">
    <div class="subsection-header">
      <span class="subsection-title">Téléchargement Direct</span>
      <span class="subsection-label label-essential">essentiel</span>
    </div>
    <div class="resource-list">
      {{ resourceCard(resources.download.direct[0], true) }}
      {{ resourceCard(resources.download.direct[1], true) }}
    </div>
  </div>

  <div class="subsection">
    <div class="subsection-header">
      <span class="subsection-title">Guides associés</span>
    </div>
    <div class="notice notice-warn">
      <span>⚠️</span>
      <span>Utilise toujours un VPN ou Real-Debrid pour le torrent. Recommandé : Mullvad ou ProtonVPN.</span>
    </div>
    <div class="guide-grid">
      <a href="{{ '/guides/guide-torrent-debutant/' | url }}" class="guide-card">
        <span class="guide-tag">// torrent</span>
        <span class="guide-title">Débuter avec les torrents</span>
        <span class="guide-desc">Client, VPN, sites fiables — tout ce qu'il faut savoir</span>
        <span class="guide-level">👶 débutant</span>
      </a>
      <a href="{{ '/guides/guide-real-debrid/' | url }}" class="guide-card">
        <span class="guide-tag">// ddl</span>
        <span class="guide-title">Configurer Real-Debrid</span>
        <span class="guide-desc">Setup complet pour du DDL à vitesse maximale</span>
        <span class="guide-level">🧠 avancé</span>
